<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolBarColor">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_18sdp" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ad_view"
        android:layout_alignParentBottom="true"
        android:layout_below="@+id/toolBar">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_15sdp">

            <!-- Inputs Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_12sdp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white"
                app:strokeColor="#E5E8E8"
                app:strokeWidth="1dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <!-- Weight Entry -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weight"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edtWeight"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/weight_hint"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:textColor="#333333"
                            android:background="@android:drawable/editbox_background"
                            android:padding="@dimen/_10sdp"/>

                        <RadioGroup
                            android:id="@+id/rgWeightUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_10sdp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatRadioButton
                                android:id="@+id/rbKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="kg"
                                android:checked="true"
                                android:textColor="#555555"
                                android:textSize="13sp"
                                app:buttonTint="@color/radio_button_tint"/>

                            <androidx.appcompat.widget.AppCompatRadioButton
                                android:id="@+id/rbLbs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_6sdp"
                                android:text="lbs"
                                android:textColor="#555555"
                                android:textSize="13sp"
                                app:buttonTint="@color/radio_button_tint"/>
                        </RadioGroup>
                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <!-- Climate Entry -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:text="@string/climate"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgClimate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbTemperate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/temperate"
                            android:checked="true"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbHot"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hot"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbCold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/cold"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>
                    </RadioGroup>

                    <!-- Activity Level -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:text="@string/activity_level"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbLow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/low"
                            android:checked="true"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/medium"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/rbHigh"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/high"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            app:buttonTint="@color/radio_button_tint"/>
                    </RadioGroup>

                    <!-- Calculate Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCalculate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:background="@drawable/default_background_rounded"
                        android:textColor="@android:color/white"
                        android:text="@string/calculate"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                </androidx.appcompat.widget.LinearLayoutCompat>
            </com.google.android.material.card.MaterialCardView>

            <!-- Result Card (Initially Gone) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#EBF5FB"
                app:strokeColor="#AED6F1"
                app:strokeWidth="1dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/_15sdp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_36sdp"
                        android:layout_height="@dimen/_36sdp"
                        android:src="@drawable/ic_water_drop"
                        android:padding="2dp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="@string/calculated_result"
                        android:textColor="#2980B9"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/txtResultGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#333333"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSetGoal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:background="@drawable/default_background_rounded"
                        android:textColor="@android:color/white"
                        android:text="@string/set_water_goal"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </androidx.appcompat.widget.LinearLayoutCompat>
            </com.google.android.material.card.MaterialCardView>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

    <RelativeLayout
        android:id="@+id/ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:gravity="center" />

</RelativeLayout>
