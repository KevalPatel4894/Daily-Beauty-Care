<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:fitsSystemWindows="true"
    tools:context=".activity.MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolBarColor"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/layoutToolbarScore"
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:clickable="true"
                android:focusable="true">

                <ProgressBar
                    android:id="@+id/toolbarScoreProgress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:progressDrawable="@drawable/circular_progress_bar_toolbar"
                    android:max="100"
                    android:padding="2dp"
                    android:progress="0" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/txtToolbarScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_gravity="center"
                android:text="@string/app_name"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_18sdp" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgSearch"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_toStartOf="@id/imgSetting"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/_12sdp"
                android:src="@drawable/ic_search" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgSetting"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/_10sdp"
                android:src="@drawable/ic_settings" />

        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ad_view"
        android:layout_alignParentBottom="true"
        android:layout_below="@+id/toolBar"
        android:fillViewport="true">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_12sdp">

            <!-- Horizontal Grid of 3 Quick Action Cards -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_marginEnd="@dimen/_12sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_4sdp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Beauty Challenges Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardChallengesBanner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:minHeight="@dimen/_95sdp"
                    android:layout_marginBottom="@dimen/_3sdp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFF0FD"
                    app:strokeColor="#F1B6D6"
                    app:strokeWidth="1dp"
                    app:rippleColor="#F1B6D6">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="@dimen/_10sdp"
                        android:paddingBottom="@dimen/_10sdp"
                        android:paddingStart="@dimen/_4sdp"
                        android:paddingEnd="@dimen/_4sdp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:src="@drawable/ic_star_rate"
                            android:tint="@color/toolBarColor"
                            android:padding="2dp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_6sdp"
                            android:gravity="center"
                            android:text="@string/beauty_challenges"
                            android:textColor="@color/toolBarColor"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/challenges_desc_short"
                            android:textColor="#666666"
                            android:textSize="10sp" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>

                <!-- Daily Check-In Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCheckInBanner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_2sdp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:minHeight="@dimen/_95sdp"
                    android:layout_marginBottom="@dimen/_3sdp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#EAFAF1"
                    app:strokeColor="#A9DFBF"
                    app:strokeWidth="1dp"
                    app:rippleColor="#A9DFBF">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="@dimen/_10sdp"
                        android:paddingBottom="@dimen/_10sdp"
                        android:paddingStart="@dimen/_4sdp"
                        android:paddingEnd="@dimen/_4sdp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/imgCheckInFlame"
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:src="@drawable/ic_streak_flame"
                            android:padding="2dp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_6sdp"
                            android:gravity="center"
                            android:text="@string/daily_check_in"
                            android:textColor="#2E7D32"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/txtCheckInSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/check_in_tap_short"
                            android:textColor="#555555"
                            android:textSize="10sp" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>

                <!-- Daily Water Tracker Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWaterTrackerBanner"
                    android:layout_width="0dp"
                    android:layout_marginBottom="@dimen/_3sdp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_2sdp"
                    android:layout_marginEnd="0dp"
                    android:minHeight="@dimen/_95sdp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#EBF5FB"
                    app:strokeColor="#AED6F1"
                    app:strokeWidth="1dp"
                    app:rippleColor="#AED6F1">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="@dimen/_10sdp"
                        android:paddingBottom="@dimen/_10sdp"
                        android:paddingStart="@dimen/_4sdp"
                        android:paddingEnd="@dimen/_4sdp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/imgWaterDrop"
                            android:layout_width="@dimen/_28sdp"
                            android:layout_height="@dimen/_28sdp"
                            android:src="@drawable/ic_water_drop"
                            android:padding="2dp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_6sdp"
                            android:gravity="center"
                            android:text="@string/water_tracker"
                            android:textColor="#2980B9"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/txtWaterSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/water_tracker_subtitle"
                            android:textColor="#555555"
                            android:textSize="10sp" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Profile Personalization Onboarding Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileOnboarding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_marginEnd="@dimen/_12sdp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFF0FD"
                app:strokeColor="#F1B6D6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_banner_title"
                        android:textColor="@color/toolBarColor"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/profile_banner_desc"
                        android:textColor="#555555"
                        android:textSize="10sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGetStartedProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="@string/profile_get_started"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/toolBarColor"
                        app:cornerRadius="6dp"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconTint="@color/white"
                        android:textSize="10sp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Personalized Recommendations Feed -->
            <LinearLayout
                android:id="@+id/layoutPersonalizedFeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_marginEnd="@dimen/_12sdp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginBottom="4dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_for_you_header"
                        android:textColor="@color/toolBarColor"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/txtProfileSummary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/_6sdp"
                        android:textColor="#777777"
                        android:textSize="10sp"
                        tools:text="(Oily Skin | Acne)"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <!-- Re-setup profile link -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/txtEditProfileLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_edit_link"
                        android:textColor="@color/toolBarColor"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPersonalizedRecommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_personalized_tip" />
            </LinearLayout>

            <!-- Mood-Based Tip Picker Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_marginEnd="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_4sdp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="#E8E8E8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/skin_mood_picker_title"
                        android:textColor="@color/toolBarColor"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/skin_mood_picker_subtitle"
                        android:textColor="#666666"
                        android:textSize="10sp" />

                    <!-- Grid Layout for 2 rows of 3 items -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/_10sdp">

                        <!-- Row 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:layout_marginBottom="@dimen/_6sdp">

                            <!-- Dull (🌚) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodDull"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#F2F3F4"
                                app:strokeColor="#D5D8DC"
                                app:strokeWidth="1dp"
                                app:rippleColor="#D5D8DC">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🌚"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_dull"
                                        android:textColor="#333333"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Oily (💦) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodOily"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:layout_marginEnd="2dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#EBF5FB"
                                app:strokeColor="#AED6F1"
                                app:strokeWidth="1dp"
                                app:rippleColor="#AED6F1">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="💦"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_oily"
                                        android:textColor="#2E86C1"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Dry (🌵) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodDry"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#FEF9E7"
                                app:strokeColor="#F9E79F"
                                app:strokeWidth="1dp"
                                app:rippleColor="#F9E79F">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🌵"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_dry"
                                        android:textColor="#B7950B"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                        <!-- Row 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- Tired (🥱) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodTired"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#F4ECF7"
                                app:strokeColor="#D7BDE2"
                                app:strokeWidth="1dp"
                                app:rippleColor="#D7BDE2">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🥱"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_tired"
                                        android:textColor="#7D3C98"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Sensitive (🛡️) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodSensitive"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:layout_marginEnd="2dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#FDEDEC"
                                app:strokeColor="#F9D3D3"
                                app:strokeWidth="1dp"
                                app:rippleColor="#F9D3D3">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🛡️"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_sensitive"
                                        android:textColor="#CB4335"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Glowing (✨) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnMoodGlowing"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="1dp"
                                app:cardBackgroundColor="#EAF2F8"
                                app:strokeColor="#A9CCE3"
                                app:strokeWidth="1dp"
                                app:rippleColor="#A9CCE3">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingVertical="@dimen/_8sdp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="✨"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/skin_mood_glowing"
                                        android:textColor="#2471A3"
                                        android:textSize="11sp"
                                        android:textStyle="bold"
                                        android:ellipsize="end"
                                        android:maxLines="1"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategory"
