<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/_10sdp">

        <!-- Badge Icon Container -->
        <FrameLayout
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginBottom="@dimen/_8sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgBadgeIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_badge_gold" />

            <!-- Lock overlay -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgBadgeLock"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                android:tint="#80000000"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Badge Name -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtBadgeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Badge Title"
            android:textColor="@color/black"
            android:textSize="@dimen/_11sdp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Badge Description -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtBadgeDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="Badge Description details go here in this text."
            android:textColor="#666666"
            android:textSize="@dimen/_8sdp"
            android:maxLines="2"
            android:ellipsize="end"
            android:minLines="2" />

        <!-- Progress meter -->
        <ProgressBar
            android:id="@+id/progressBadge"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/toolBarColor"
            android:progressBackgroundTint="#F0F0F0" />

        <!-- Progress status text -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtBadgeProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Progress: 0 / 5"
            android:textColor="#555555"
            android:textSize="@dimen/_8sdp" />

        <!-- Status Tag (Locked/Unlocked) -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtBadgeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6sdp"
            android:background="#EFEFEF"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Locked"
            android:textColor="#777777"
            android:textSize="@dimen/_7sdp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
