<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolBarColor">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/txtTabTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/settings_profile"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_18sdp" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ad_view"
        android:layout_below="@+id/toolBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_16sdp">

            <!-- Welcome / Intro header -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_intro_title"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_15sdp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_intro_desc"
                android:textColor="#555555"
                android:textSize="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_20sdp" />

            <!-- Skin Type Selector -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_skin_type_label"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_10"
                android:paddingHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_6sdp">

                <Spinner
                    android:id="@+id/spinnerSkinType"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp"
                    android:textColor="@color/black" />
            </FrameLayout>

            <!-- Quiz link Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSkinTestLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_16sdp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FDF2F4"
                app:strokeColor="#FADBD8"
                app:strokeWidth="1dp"
                app:rippleColor="#FADBD8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/_8sdp"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_star_rate"
                        android:tint="@color/toolBarColor" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/_8sdp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_skin_test_prompt"
                            android:textColor="@color/toolBarColor"
                            android:textSize="@dimen/_9sdp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_skin_test_desc"
                            android:textColor="#884A39"
                            android:textSize="@dimen/_8sdp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_12sdp"
                        android:layout_height="@dimen/_12sdp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/toolBarColor" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hair Type Selector -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_hair_type_label"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_10"
                android:paddingHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_16sdp">

                <Spinner
                    android:id="@+id/spinnerHairType"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp" />
            </FrameLayout>

            <!-- Age Group Selector -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_age_group_label"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_10"
                android:paddingHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_16sdp">

                <Spinner
                    android:id="@+id/spinnerAgeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp" />
            </FrameLayout>

            <!-- Primary Concern Selector -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_concern_label"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_10"
                android:paddingHorizontal="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_24sdp">

                <Spinner
                    android:id="@+id/spinnerPrimaryConcern"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp" />
            </FrameLayout>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diary_save"
                android:textColor="@color/white"
                app:backgroundTint="@color/toolBarColor"
                android:paddingVertical="@dimen/_10sdp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <RelativeLayout
        android:id="@+id/ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:gravity="center" />

</RelativeLayout>
