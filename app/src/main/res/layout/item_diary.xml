<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/_10sdp"
        android:gravity="center_vertical">

        <!-- Optional Thumbnail Photo Log wrapped in CardView for clipping -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDiaryThumbnail"
            android:layout_width="@dimen/_55sdp"
            android:layout_height="@dimen/_55sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            tools:visibility="visible">
            
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgDiaryThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_book" />
        </androidx.cardview.widget.CardView>

        <!-- Text details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtDiaryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-06-26"
                android:textColor="@color/toolBarColor"
                android:textSize="@dimen/_9sdp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtDiaryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Diary Entry Title"
                android:textColor="@color/black"
                android:textSize="@dimen/_12sdp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtDiarySnippet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="This is a detailed snippet of what notes you have taken during your self care log today..."
                android:textColor="#555555"
                android:textSize="@dimen/_9sdp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Arrow indicator -->
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginStart="@dimen/_8sdp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="#888888" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
